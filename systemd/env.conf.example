# Environment variables for mc-qq-bridge
# Copy this file to /etc/mc-qq-bridge/env.conf and edit as needed

# WebSocket URL of the LLBot/OneBot v11 server
WS_URL=ws://127.0.0.1:8777

# Docker container name of the Minecraft server
CONTAINER=minecraft-server

# QQ group ID to forward messages to/from
GROUP_ID=1079823701

# Heartbeat interval in milliseconds (default: 25000)
HEARTBEAT_INTERVAL=25000

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
